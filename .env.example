# =============================================================
#  BARBER IA — Barbershop Bot
#  Copie este arquivo para .env e preencha os valores
# =============================================================

# Banco de dados PostgreSQL
DATABASE_URL=postgres://barber_user:SENHA@SERVICO_POSTGRES:5432/barberbot?sslmode=disable

# Redis
REDIS_URL=redis://default:SENHA@SERVICO_REDIS:6379

# Chatwoot
CHATWOOT_URL=https://SEU_CHATWOOT.easypanel.host
CHATWOOT_TOKEN=SEU_TOKEN_CHATWOOT
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_WEBHOOK_SECRET=GERE_UM_SECRET_ALEATORIO

# Inteligência Artificial
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_KEY=

# Google (TTS — opcional)
GOOGLE_API_KEY=

# Segurança
JWT_SECRET_KEY=GERE_UMA_CHAVE_64_CHARS

# MODO SEM LOGIN (apenas teste!) — PADRÃO = true (login desligado), trata
# qualquer requisição como admin_master. NUNCA use com dados reais/produção.
# Para RELIGAR o login: AUTH_DISABLED=false (backend) e
# NEXT_PUBLIC_AUTH_DISABLED=false (frontend, no build).
AUTH_DISABLED=true
DEV_ADMIN_EMAIL=admin@barber.com

# Aplicação
APP_MODE=both
PORT=8000

# Frontend
FRONTEND_URL=https://SEU_FRONTEND.easypanel.host

# E-mail (opcional)
SMTP_DOMAIN=
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_OPENSSL_VERIFY_MODE=peer
MAILER_INBOUND_EMAIL_DOMAIN=
MAILER_SENDER_EMAIL="Barber IA <noreply@seudominio.com>"

# ImageKit (opcional)
IMAGEKIT_ID=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
